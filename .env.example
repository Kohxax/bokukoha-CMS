# ─── 認証 ────────────────────────────────────────────────────────────────────

# セッション暗号化キー（nuxt-auth-utils）
# 32文字以上のランダム文字列。openssl rand -hex 32 などで生成
NUXT_SESSION_PASSWORD=

# 管理者パスワードのbcryptハッシュ
# 生成方法: node -e "const bcrypt=require('bcrypt'); bcrypt.hash('YOUR_PASS',12).then(console.log)"
NUXT_ADMIN_PASSWORD_HASH=

NUXT_TOTP_SECRET=

# ─── データベース ─────────────────────────────────────────────────────────────

# SQLiteファイルのパス（Dockerでは /app/data/cms.db 固定）
NUXT_DB_PATH=/app/data/cms.db

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────

# CloudflareアカウントID（ダッシュボード右下に表示）
NUXT_R2_ACCOUNT_ID=

# R2 APIトークンのアクセスキーID
# Workers & Pages → R2 → Manage R2 API Tokens → Create API token
NUXT_R2_ACCESS_KEY_ID=

# R2 APIトークンのシークレット
NUXT_R2_SECRET_ACCESS_KEY=

# R2バケット名
NUXT_R2_BUCKET_NAME=

# R2公開URLのカスタムドメイン（末尾スラッシュなし）
# R2バケット → Settings → Custom Domains で設定
NUXT_R2_PUBLIC_URL=https://images.bokukoha.dev

# ─── Cloudflare─────────────────────────────────────────────

# ブログの自動再ビルドをトリガーするDeploy Hook URL
# Cloudflare Pages → プロジェクト → Settings → Builds & deployments → Deploy Hooks
# 未設定の場合はデプロイフックをスキップ（ローカル開発時は空でOK）
NUXT_CF_DEPLOY_HOOK_URL=

CLOUDFLARE_TUNNEL_TOKEN=